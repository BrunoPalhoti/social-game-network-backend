POSTGRES_PASSWORD=gamerverse
POSTGRES_DB=gamerverse

# Host 'postgres' e o nome do service dentro do Docker network do compose
DATABASE_URL=postgres://gamerverse:gamerverse@postgres:5432/gamerverse
